{
  "name": "mcp-agency-workflow-server",
  "version": "1.1.0",
  "description": "MCP Workflow Server with dashboard — built for digital marketing agencies",
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc && node scripts/validate-dashboard.mjs",
    "build:client": "cd client && npm install && npx vite build",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "dev:client": "cd client && npx vite"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.75.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/multer": "^2.1.0",
    "cookie-session": "^2.1.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.4.0",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.16.0",
    "typescript": "^5.7.0"
  }
}
